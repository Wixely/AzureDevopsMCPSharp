{
  "AzureDevOps": {
    "OrganizationUrl": "https://tfsserver.lan/DefaultCollection",
    "PersonalAccessToken": "",
    "DefaultProject": "",
    "ReadOnly": true,
    "Operations": {
      "queue_pipeline_run": true,
      "cancel_pipeline_run": true,
      "add_pipeline_run_tags": true,
      "remove_pipeline_run_tag": true,
      "create_pipeline": true,
      "rename_pipeline": true,
      "move_pipeline": true,
      "delete_pipeline": false,
      "authorize_pipeline_resource": true,
      "create_work_item": true,
      "update_work_item": true
    }
  },
  "Server": {
    "Host": "localhost",
    "Port": 5089,
    "Path": "/mcp"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/azdomcp-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 52428800,
          "rollOnFileSizeLimit": true,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ]
  }
}
